{
  "name": "PixelRoot32-Game-Engine",
  "description": "PixelRoot32-Game-Engine is a lightweight, modular 2D game engine written in C++17, designed primarily for ESP32 microcontrollers, with a native simulation layer for PC (SDL2) to enable rapid development without hardware.",
  "keywords": [
    "esp32",
    "game-engine",
    "graphics",
    "retro",
    "engine",
    "tft_espi",
    "u8g2",
    "sdl2"
  ],
  "version": "1.2.0",
  "build": {
    "srcDir": "src",
    "includeDir": "include"
  },
  "authors": [
    {
      "name": "Gabriel Perez",
      "email": "perezgabriel89@hotmail.com",
      "url": "https://github.com/gperez88",
      "maintainer": true
    }
  ],
  "license": "MIT",
  "dependencies": {
    "TFT_eSPI": "^2.5.43",
    "U8g2": "^2.36.4",
    "OneButton": "^2.6.1"
  },
  "frameworks": [],
  "platforms": [
    "espressif32",
    "native"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/PixelRoot32-Game-Engine/PixelRoot32-Game-Engine.git"
  },
  "examples": [
    {
      "name": "Hello World",
      "base": "examples/hello_world",
      "files": ["platformio.ini", "src/**/*.cpp", "src/**/*.h", "include/**", "lib/**", "README*", ".gitignore"]
    },
    {
      "name": "Sprites Demo",
      "base": "examples/sprites",
      "files": ["platformio.ini", "src/**/*.cpp", "src/**/*.h", "include/**", "lib/**", "README*", ".gitignore"]
    },
    {
      "name": "Dual Palette Demo",
      "base": "examples/dual_palette",
      "files": ["platformio.ini", "src/**/*.cpp", "src/**/*.h", "include/**", "lib/**", "README*", ".gitignore"]
    },
    {
      "name": "Physics Demo",
      "base": "examples/physics",
      "files": ["platformio.ini", "src/**/*.cpp", "src/**/*.h", "include/**", "lib/**", "README*", ".gitignore"]
    },
    {
      "name": "Animated Tilemap",
      "base": "examples/animated_tilemap",
      "files": ["platformio.ini", "src/**/*.cpp", "src/**/*.h", "include/**", "lib/**", "README*", ".gitignore"]
    },
    {
      "name": "Camera Demo",
      "base": "examples/camera",
      "files": ["platformio.ini", "src/**/*.cpp", "src/**/*.h", "include/**", "lib/**", "README*", ".gitignore"]
    },
    {
